<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.3" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.3" PrivateAssets="all" />
  </ItemGroup>

  <Target Name="GenerateAppSettings" BeforeTargets="BeforeBuild">
    <Exec Command="powershell -Command &quot;if (Test-Path .env) { $content = Get-Content .env; $keyLine = $content | Select-String -Pattern '^ACCESS_KEY=' | Select-Object -First 1; if ($keyLine) { $key = ($keyLine.ToString() -split '=', 2)[1].Trim(); $json = '{\&quot;EmailSettings\&quot;: {\&quot;AccessKey\&quot;: \&quot;' + $key + '\&quot;}}'; Set-Content -Path wwwroot/appsettings.Development.json -Value $json -Force; Set-Content -Path wwwroot/appsettings.Production.json -Value $json -Force } }&quot;" />
  </Target>

</Project>
