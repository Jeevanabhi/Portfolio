<!-- Skills Section Component -->
@page "/Skills"
<section id="skills" class="skills-section reveal-on-scroll">

    <div class="skills-header">
        <span class="skills-tag">WHAT I KNOW</span>
        <h2 class="skills-title">My <span class="highlight">Skills</span></h2>
        <p class="skills-sub">Technologies and tools I work with to bring ideas to life.</p>
    </div>

    <div class="skills-grid">
        @foreach (var skill in skills)
        {
            <div class="skill-card">
                <div class="skill-icon">@((MarkupString)skill.Icon)</div>
                <span class="skill-name">@skill.Name</span>
            </div>
        }
    </div>

</section>

